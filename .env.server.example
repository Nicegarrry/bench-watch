# Required: Postgres connection string
# For local dev with `wasp start db`, use the URL printed in its output
# For production: Supabase connection string
DATABASE_URL=postgresql://postgresWaspDevUser:postgresWaspDevPass@localhost:5432/bench-watch-dev

# Required: Anthropic API key for Claude AI calls (pipeline phases 2a, 2c, 3)
ANTHROPIC_API_KEY=sk-ant-api03-...

