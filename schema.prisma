datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                      String    @id @default(uuid())
  username                String
  displayName             String?
  plan                    String    @default("free")
  onboarded               Boolean   @default(false)
  dashboardRunsThisWeek   Int       @default(0)
  dashboardRunsResetAt    DateTime?
  lastNotifSeenAt         DateTime?
  createdAt               DateTime  @default(now())

  userAreas  UserArea[]
  userDigests UserDigest[]
  emailSends  EmailSend[]
}

model RssFeedRegistry {
  id               String    @id @default(cuid())
  courtCode        String    @unique
  courtName        String
  source           String    @default("jade")
  feedUrl          String
  tier             Int       @default(1)
  isActive         Boolean   @default(true)
  lastPolledAt     DateTime?
  lastSuccessfulAt DateTime?
  lastError        String?
  lastHttpStatus   Int?
  itemsLastPoll    Int       @default(0)

  @@map("rss_feed_registry")
}

model LawArea {
  slug             String   @id
  name             String
  description      String?
  searchTerms      String[]
  catchwordPatterns String[]
  icon             String?
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)

  userAreas         UserArea[]
  caseAreaTags      CaseAreaTag[]
  legislationAreaTags LegislationAreaTag[]

  @@map("law_areas")
}

model UserArea {
  id             String  @id @default(cuid())
  userId         String
  areaSlug       String
  emailFrequency String  @default("weekly")

  user User    @relation(fields: [userId], references: [id])
  area LawArea @relation(fields: [areaSlug], references: [slug])

  @@unique([userId, areaSlug])
  @@map("user_areas")
}

model Case {
  id              String    @id @default(cuid())
  citation        String    @unique
  caseName        String
  court           String
  courtCode       String
  decisionDate    DateTime?
  austliiUrl      String?
  jadeUrl         String?
  catchwords      String?
  judgmentExcerpt String?
  excerptFetched  Boolean   @default(false)
  bench           String?
  orders          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  caseAreaTags          CaseAreaTag[]
  caseAnalysis          CaseAnalysis?
  topDigestEntries      UserDigestTopCase[]
  extendedDigestEntries UserDigestExtendedCase[]

  @@map("cases")
}

model CaseAreaTag {
  caseId              String
  areaSlug            String
  relevanceConfidence Float  @default(0.5)
  assignedBy          String @default("triage_claude")

  case Case    @relation(fields: [caseId], references: [id])
  area LawArea @relation(fields: [areaSlug], references: [slug])

  @@id([caseId, areaSlug])
  @@map("case_area_tags")
}

model CaseAnalysis {
  id                     String   @id @default(cuid())
  caseId                 String   @unique
  factsSummary           String
  legalAnalysis          String
  whyItMatters           String
  significanceScore      Int
  scoreJustification     String?
  primaryArea            String
  secondaryAreas         String[]
  classificationReasoning String?
  modelUsed              String
  generatedAt            DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id])

  @@map("case_analyses")
}

model DiscoveryRun {
  id              String    @id @default(cuid())
  periodType      String    @default("weekly")
  periodStart     DateTime
  periodEnd       DateTime
  status          String    @default("running")
  courtsPolled    String[]
  casesDiscovered Int       @default(0)
  casesTriaged    Int       @default(0)
  casesAnalysed   Int       @default(0)
  errorMessage    String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@map("discovery_runs")
}

model UserDigest {
  id            String    @id @default(cuid())
  userId        String
  periodType    String    @default("weekly")
  periodStart   DateTime
  periodEnd     DateTime
  areaSlugs     String[]
  status        String    @default("pending")
  digestSummary String?
  modelUsed     String?
  tokensUsed    Int?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  user           User                     @relation(fields: [userId], references: [id])
  topCases       UserDigestTopCase[]      @relation("DigestTopCases")
  extendedCases  UserDigestExtendedCase[] @relation("DigestExtendedCases")
  emailSends     EmailSend[]

  @@map("user_digests")
}

model UserDigestTopCase {
  id                String @id @default(cuid())
  digestId          String
  caseId            String
  rank              Int
  factsSummary      String
  legalAnalysis     String
  whyItMatters      String
  significanceScore Int
  primaryArea       String

  digest UserDigest @relation("DigestTopCases", fields: [digestId], references: [id])
  case   Case       @relation(fields: [caseId], references: [id])

  @@map("user_digest_top_cases")
}

model UserDigestExtendedCase {
  id                String @id @default(cuid())
  digestId          String
  caseId            String
  rank              Int
  significanceScore Int
  primaryArea       String
  oneLineSummary    String

  digest UserDigest @relation("DigestExtendedCases", fields: [digestId], references: [id])
  case   Case       @relation(fields: [caseId], references: [id])

  @@map("user_digest_extended_cases")
}

model EmailSend {
  id        String    @id @default(cuid())
  userId    String
  digestId  String?
  sentAt    DateTime  @default(now())
  status    String    @default("pending")
  emailType String

  user   User        @relation(fields: [userId], references: [id])
  digest UserDigest? @relation(fields: [digestId], references: [id])

  @@map("email_sends")
}

// ── Legislation Pipeline ──────────────────────────────────────────────────────

model LegislationFeedRegistry {
  id               String    @id @default(cuid())
  jurisdiction     String    // "cth", "nsw", "vic", "qld", "wa", "sa", "tas", "act", "nt"
  jurisdictionName String
  feedUrl          String
  feedType         String    // "atom", "rss", "html-scrape"
  tier             Int       @default(1) // 1=direct jurisdiction site, 2=austlii/fallback
  isActive         Boolean   @default(true)
  lastPolledAt     DateTime?
  lastSuccessfulAt DateTime?
  lastError        String?
  lastHttpStatus   Int?
  itemsLastPoll    Int       @default(0)
  createdAt        DateTime  @default(now())

  @@map("legislation_feed_registry")
}

model LegislationChange {
  id             String    @id @default(cuid())
  externalId     String    @unique // URL or guid from feed item
  title          String
  jurisdiction   String    // "cth", "nsw", etc.
  changeType     String    @default("unknown") // "act_new", "act_amended", "act_commenced", "regulation_made", "bill_introduced"
  legislationUrl String?   // Source URL on jurisdiction site
  austliiUrl     String?   // AustLII URL if known
  publishedAt    DateTime
  feedSummary    String?   // Raw description from feed
  fullText       String?   // Fetched full text (truncated to 100KB)
  textFetched    Boolean   @default(false)
  source         String    // Feed URL that produced this record
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  areaTags LegislationAreaTag[]
  analysis LegislationChangeAnalysis?

  @@map("legislation_changes")
}

model LegislationAreaTag {
  changeId            String
  areaSlug            String
  relevanceConfidence Float  @default(0.5)
  assignedBy          String @default("ai")

  change  LegislationChange @relation(fields: [changeId], references: [id])
  lawArea LawArea           @relation(fields: [areaSlug], references: [slug])

  @@id([changeId, areaSlug])
  @@map("legislation_area_tags")
}

model LegislationChangeAnalysis {
  id                String   @id @default(cuid())
  changeId          String   @unique
  changeSummary     String   // Plain-English: what changed
  practiceImpact    String   // Why it matters to practitioners
  affectedAreas     String[] // Primary area slugs
  significanceScore Int      // 1-10
  modelUsed         String
  generatedAt       DateTime @default(now())

  change LegislationChange @relation(fields: [changeId], references: [id])

  @@map("legislation_change_analyses")
}
